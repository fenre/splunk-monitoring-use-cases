  "meraki:assurancealerts": {
    "has_data_on_test_server": true,
    "device_type_values": ["MX", "MS", "MR", "MV", "MT", "MG"],
    "device_id_path": "scope.devices{}.serial",
    "device_name_path": "scope.devices{}.name",
    "device_mac_path": "scope.devices{}.mac",
    "device_product_type_path": "scope.devices{}.productType",
    "network_id_path": "network.id",
    "network_name_path": "network.name",
    "open_alert_filter": "dismissedAt=\"null\"",
    "fields_canonical": [
      "alert_description","alert_id","alert_severity","categoryType","cursor","description","deviceType","dismissedAt","expiresAt","id","network.id","network.name","organizationId","resolvedAt","schemaVersion","scope.devices{}.mac","scope.devices{}.name","scope.devices{}.nodeId","scope.devices{}.productType","scope.devices{}.serial","scope.devices{}.url","severity","signature","startedAt","title","type"
    ],
    "fields_NOT_present": ["deviceSerial","deviceName","networkName","networkId"],
    "notes": "deviceType is the model-family code (MR/MS/MX/MT/MV/MG), NOT the lowercase API productType. dismissedAt is the literal string \"null\" while open, NOT a Splunk NULL — use search dismissedAt=\"null\" instead of where isnull(dismissedAt)."
  },
  "meraki:devices": {
    "has_data_on_test_server": true,
    "device_id_path": "serial",
