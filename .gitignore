# OS
.DS_Store
Thumbs.db

# Python
__pycache__/
*.py[cod]
*.pyo
.Python
.venv/
.venv-feasibility/
venv/
env/

# IDE / editor
.idea/
.vscode/
.cursor/
*.swp
*.swo
*~

# ── v7.0 build output (regenerated by tools/build/build.py) ────────────
# `dist/` is the deployable artefact; it is rebuilt fresh on every CI
# run and never committed. See docs/architecture.md for the contract.
dist/
dist1/
dist2/

# Reproducibility-check temp dirs.
.build-tmp/

# Local build-comparison dirs created by docs/migration-build-parity.md workflow.
dist-legacy/
dist-content/
dist-before/

# Per-task build dirs from parallel worktrees (see docs/parallel-execution-substrate.md).
dist-*/

# Per-worktree pip cache when PIP_CACHE_DIR=$(pwd)/.pip-cache is set.
.pip-cache/

# pytest cache (mcp/ has a nested .gitignore but this covers the root).
.pytest_cache/

# ── Generated artefacts ───────────────────────────────────────────────
# These files are regenerated by `python3 tools/build/build.py`. They remain
# *tracked* in git because validate.yml diffs them after each build to
# detect regressions. The gitignore entries below prevent extra copies
# from appearing in untracked-file noise after local builds.
data.js
catalog.json
provenance.json
provenance.js
non-technical-view.js
llms.txt
llm.txt
llms-full.txt
sitemap.xml
scorecard.html
scorecard.json
regulatory-primer.html
api-docs.html
mitre_techniques.json
recently-added.json

# Built Splunk app packages (regenerated by scripts/package_ta.sh)
*.spl

# CI / local test runner output (regenerated by scripts/run_uc_tests.py and audit_splunk_cloud_compat.py)
test-results/

# Local deploy state — touched by scripts/deploy_to_splunk.sh to detect
# which Splunk configs changed since the last push. Per-machine state.
.deploy-marker

.ci-tools/
.build-test/
.coverage

# Local smoke build directory — `python3 tools/build/build.py --out .build-smoke`
# leaves a 7000+ file tree behind. Regenerated, never committed.
.build-smoke/

# Git worktrees for rollback-safe feature work. Each entry under .worktrees/
# is a separate `git worktree add` checkout on its own branch; the directory
# itself is local-only and must never be tracked in the main worktree.
.worktrees/

# Local secrets (Splunk REST token, etc.) – do not commit. The
# `secrets.env.example` template IS tracked so contributors can copy it
# to `secrets.env` and substitute their own tokens.
secrets.env
.env
.env.local

# Environment-specific files (kept locally, not part of the core repo)
other/

# Internal notes and non-website assets
spl-review-findings.md
*.PDF
*.pptx
traffic/data.json

# Legacy binary tools (use the web version in tools/ instead)
*.xlsm

# Original DSA folder (migrated to tools/data-sizing/)
Data Assessement tool/

# Node.js — runtime dependencies and lockfile are tracked so that the
# feasibility harness and Ajv-based OSCAL validator are reproducible in CI.
node_modules/

# ── Legacy /api/ tree (regenerated by scripts/generate_api_surface.py) ─
# Every file under api/ is gitignored EXCEPT api/README.md, the
# hand-maintained explainer. v7.0+ generates the same tree into
# dist/api/; the workspace copy stays gitignored so contributors don't
# commit drifted snapshots.
api/*
!api/README.md

# Upstream regulatory artefacts (132 MB: atomic-red-team, MITRE ATT&CK STIX,
# NIST OSCAL catalogs, D3FEND ontology, CPRT crosswalks, OLIR). Fetched on
# demand by scripts/ingest_all.py and refreshed weekly by the Phase 5.3
# regulatory-watch workflow (.github/workflows/regulatory-watch.yml) — there
# is no reason to carry them in git history.
vendor/

# Feasibility-spike generated artefacts (regenerated by the scripts under
# scripts/feasibility/). Machine output from reproducible generators has no
# reason to live in git history.
build/poc/

# Splunk dashboards and deployment tooling (separate from the use case catalog)
dashboards/
scripts/deploy_dashboard_studio_rest.py
scripts/generate_uc_dashboards.py
scripts/generate_catalog_dashboard.py

# Local scratch / external read-only references (Splunkbase apps under
# inspection, third-party SPL corpora used as authoring references).
# Never committed; refreshed manually by the maintainer.
external/
.corpus-survey/
# Splunkbase app archives downloaded for local extraction under external/.
# Anchored to the repo root only so .ci-tools/gitleaks.tar.gz and any nested
# vendor archive (e.g. dist/, vendor/) stay reachable to git as before.
/*.tgz
/*.tar.gz
# Generated local-only SPL reference vocabulary built from external/
# corpora by tools/research/build_spl_reference.py. Treated as a local
# enrichment layer for audit-spl-references; never committed because
# the Searchbase content used to build it falls under Splunk General
# Terms (not redistributable).
data/spl-reference.local.json

# ── F21 close (2026-05-18): retire the in-tree UC-X.Y.Z.md companions ─
# The 7,761 ``content/cat-*/UC-*.md`` files were deleted on 2026-05-18.
# They were always generated artefacts (originally by
# ``python -m splunk_uc generate-md-from-json`` against the JSON SSOT
# in the same directory), but never consumed by the build pipeline —
# ``tools/build/parse_content.py`` reads the JSON sidecars exclusively
# and ``tools/build/templates/uc.py::render_markdown_twin`` emits the
# canonical per-UC markdown twin at ``dist/uc/UC-X.Y.Z/uc.md`` for
# the public site. The gitignore entry below blocks accidental
# re-introduction. See ADR-0009 §"Out of scope (post-F21 close)" and
# docs/health-check-2026-progress.md F21 row for the rationale.
content/cat-*/UC-*.md
