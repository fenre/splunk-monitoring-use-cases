{
  "description": "Sample event stream that exercises UC-22.35.1 (audit-log continuity). The 'positive' segment simulates a sourcetype with continuous events then a 90-second silence; the 'negative' segment simulates a sourcetype with normal event-rate jitter (~20s gaps).",
  "positiveCase": {
    "sourcetype": "wineventlog:security",
    "events": [
      { "_time": "2026-04-16T10:00:05Z", "event_rate": 12 },
      { "_time": "2026-04-16T10:01:05Z", "event_rate": 10 },
      { "_time": "2026-04-16T10:02:05Z", "event_rate": 11 },
      { "_time": "2026-04-16T10:03:05Z", "event_rate": 13 },
      { "_time": "2026-04-16T10:04:05Z", "event_rate": 0 },
      { "_time": "2026-04-16T10:05:05Z", "event_rate": 0 },
      { "_time": "2026-04-16T10:06:05Z", "event_rate": 11 }
    ],
    "expectedFire": true,
    "expectedSourcetype": "wineventlog:security",
    "expectedGapSeconds": 120
  },
  "negativeCase": {
    "sourcetype": "cisco:asa",
    "events": [
      { "_time": "2026-04-16T10:00:05Z", "event_rate": 5 },
      { "_time": "2026-04-16T10:00:25Z", "event_rate": 3 },
      { "_time": "2026-04-16T10:00:50Z", "event_rate": 4 },
      { "_time": "2026-04-16T10:01:15Z", "event_rate": 5 },
      { "_time": "2026-04-16T10:01:45Z", "event_rate": 4 },
      { "_time": "2026-04-16T10:02:10Z", "event_rate": 3 }
    ],
    "expectedFire": false,
    "expectedSourcetype": "cisco:asa",
    "notes": "Gaps of up to 30 seconds are normal Cisco ASA syslog jitter and must not trigger the UC."
  }
}
