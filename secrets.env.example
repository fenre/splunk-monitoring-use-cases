# Copy to secrets.env (gitignored) and fill in. Do not commit real values.
#
# Splunk REST token: Settings → Tokens → New token (capabilities: search, rest, etc.)
SPLUNK_REST_TOKEN=

# Optional — defaults shown in deploy script if unset
# SPLUNK_HOST=192.168.12.45
# SPLUNK_PORT=8089
# SPLUNK_APP=search
# SPLUNK_OWNER=your_splunk_username
