  "dataSources": {
    "ds_avail": {
      "type": "ds.search",
      "options": {
        "query": "| makeresults | eval availability=99.7 | fields availability",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now"
        }
      },
      "name": "ds_avail"
    },
    "ds_down": {
      "type": "ds.search",
      "options": {
        "query": "| makeresults | eval devices_down=3 | fields devices_down",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now"
        }
      },
      "name": "ds_down"
    },
    "ds_alerts": {
      "type": "ds.search",
      "options": {
        "query": "| makeresults | eval critical_alerts=5 | fields critical_alerts",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now"
        }
      },
      "name": "ds_alerts"
    },
    "ds_lat": {
      "type": "ds.search",
      "options": {
        "query": "| makeresults | eval avg_latency_ms=42.3 | fields avg_latency_ms",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now"
        }
      },
      "name": "ds_lat"
    },
    "ds_tput": {
      "type": "ds.search",
      "options": {
        "query": "| makeresults | eval throughput_gbps=12.47 | fields throughput_gbps",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now"
        }
      },
      "name": "ds_tput"
    },
    "ds_avail_trend": {
      "type": "ds.search",
      "options": {
        "query": "| makeresults count=96 | streamstats count as i | eval _time=relative_time(now(), \"-24h\")+(i-1)*900 | eval val=case(i>=58 AND i<=60,98.2, i>=61 AND i<=63,97.1, i>=64 AND i<=66,98.5, i>=67 AND i<=68,99.2, 1=1,99.5+(i%7)*0.08) | eval \"Availability %\"=round(val,1) | fields _time \"Availability %\"",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now"
        }
      },
      "name": "ds_avail_trend"
    },
    "ds_dev_status": {
      "type": "ds.search",
      "options": {
        "query": "| makeresults count=4 | streamstats count as i | eval site=case(i=1,\"Stavanger\",i=2,\"Southern NS\",i=3,\"Central NS\",i=4,\"Northern NS\") | eval Online=case(i=1,94,i=2,137,i=3,86,i=4,62) | eval Degraded=case(i=1,0,i=2,3,i=3,2,i=4,4) | eval Offline=case(i=1,0,i=2,1,i=3,1,i=4,2) | fields site Online Degraded Offline",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now"
        }
      },
      "name": "ds_dev_status"
    },
    "ds_errors": {
      "type": "ds.search",
      "options": {
        "query": "| makeresults count=8 | streamstats count as i | eval interface=case(i=1,\"ref01 Gi1/0/24\",i=2,\"pipe03 Gi0/0/1\",i=3,\"off02 Te1/0/1\",i=4,\"hq-core Gi2/12\",i=5,\"ref02 Eth1/3\",i=6,\"pipe07 Gi1/48\",i=7,\"dc01 Eth1/15\",i=8,\"off01 Gi0/0/0\") | eval total_errors=case(i=1,4821,i=2,3156,i=3,2847,i=4,1923,i=5,1654,i=6,1203,i=7,987,i=8,756) | fields interface total_errors",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now"
        }
      },
      "name": "ds_errors"
    },
    "ds_threats": {
      "type": "ds.search",
      "options": {
        "query": "| makeresults count=24 | streamstats count as i | eval _time=relative_time(now(), \"-24h\")+(i-1)*3600 | eval \"Threat Events\"=case(i>=14 AND i<=16,35+(i%3)*8, i%4=0,14, i%4=1,9, i%4=2,17, 1=1,11) | fields _time \"Threat Events\"",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now"
        }
      },
      "name": "ds_threats"
    },
    "ds_map": {
      "type": "ds.search",
      "options": {
        "query": "| makeresults count=8 | streamstats count as i | eval name=case(i=1,\"Stavanger Ops Centre\",i=2,\"Johan Sverdrup\",i=3,\"Ekofisk Complex\",i=4,\"Gullfaks A\",i=5,\"Troll A\",i=6,\"Oseberg Field Centre\",i=7,\"Statfjord B\",i=8,\"Draugen Platform\") | eval lat=case(i=1,58.97,i=2,58.85,i=3,56.55,i=4,61.17,i=5,60.64,i=6,60.50,i=7,61.25,i=8,64.35) | eval lon=case(i=1,5.73,i=2,2.52,i=3,3.21,i=4,2.27,i=5,3.73,i=6,2.83,i=7,1.85,i=8,7.78) | eval status=case(i=1,\"Healthy\",i=2,\"Healthy\",i=3,\"Warning\",i=4,\"Healthy\",i=5,\"Healthy\",i=6,\"Critical\",i=7,\"Healthy\",i=8,\"Critical\") | eval devices=case(i=1,94,i=2,72,i=3,68,i=4,56,i=5,48,i=6,42,i=7,38,i=8,24) | fields name lat lon status devices",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now"
        }
      },
      "name": "ds_map"
    },
    "ds_site_health": {
      "type": "ds.search",
      "options": {
        "query": "| makeresults count=8 | streamstats count as i | eval Site=case(i=1,\"Stavanger Ops Centre\",i=2,\"Johan Sverdrup\",i=3,\"Ekofisk Complex\",i=4,\"Gullfaks A\",i=5,\"Troll A\",i=6,\"Oseberg Field Centre\",i=7,\"Statfjord B\",i=8,\"Draugen Platform\") | eval Devices=case(i=1,94,i=2,72,i=3,68,i=4,56,i=5,48,i=6,42,i=7,38,i=8,24) | eval Online=case(i=1,94,i=2,72,i=3,66,i=4,56,i=5,48,i=6,40,i=7,38,i=8,22) | eval Offline=Devices-Online | eval \"Avail %\"=round(Online/Devices*100,1) | eval \"Events (24h)\"=case(i=1,14210,i=2,9856,i=3,7432,i=4,5214,i=5,4876,i=6,3891,i=7,3245,i=8,1987) | eval Health=case('Avail %'>=99,\"Healthy\",'Avail %'>=95,\"Warning\",1=1,\"Critical\") | sort -\"Avail %\" | fields Site Devices Online Offline \"Avail %\" \"Events (24h)\" Health",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now"
        }
      },
      "name": "ds_site_health"
    }
  },
