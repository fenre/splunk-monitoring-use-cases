<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>$email_subject</title>
</head>
<body style="margin:0;padding:0;background-color:#f4f4f4;font-family:Arial,Helvetica,sans-serif;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f4f4;padding:16px 0;">
    <tr>
      <td align="center">
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="background-color:#ffffff;border:1px solid #dddddd;">
          <tr>
            <td style="padding:20px 24px;background-color:#1a1a2e;color:#ffffff;font-size:18px;font-weight:bold;">
              $email_subject
            </td>
          </tr>
          <tr>
            <td style="padding:20px 24px;color:#333333;font-size:14px;line-height:1.5;">
              <p style="margin:0 0 12px 0;"><strong>Use case:</strong> $uc_id — $title</p>
              <p style="margin:0 0 12px 0;"><strong>Severity tier:</strong> $criticality ($email_tone_class)</p>
              <p style="margin:0 0 12px 0;">$email_tone_body</p>
              <p style="margin:0 0 12px 0;">$description</p>
              <p style="margin:0 0 12px 0;"><strong>Catalogue link:</strong>
                <a href="$uc_url" style="color:#0066cc;">$uc_url</a>
              </p>
              <p style="margin:0 0 12px 0;"><strong>Detected at:</strong> $timestamp_placeholder</p>
              <p style="margin:0;"><strong>SPL summary:</strong> $runtime_spl_summary</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
