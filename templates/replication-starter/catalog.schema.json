{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/replication-starter/catalog.schema.json",
  "title": "Replication Starter Catalog",
  "type": "object",
  "required": ["data", "total_uc"],
  "properties": {
    "data": {
      "type": "array",
      "items": { "$ref": "#/$defs/category" }
    },
    "total_uc": { "type": "integer", "minimum": 0 }
  },
  "$defs": {
    "category": {
      "type": "object",
      "required": ["i", "n", "s"],
      "properties": {
        "i": { "type": "integer", "minimum": 1, "description": "Category ID" },
        "n": { "type": "string", "description": "Category name" },
        "s": {
          "type": "array",
          "items": { "$ref": "#/$defs/subcategory" }
        }
      }
    },
    "subcategory": {
      "type": "object",
      "required": ["i", "n", "u"],
      "properties": {
        "i": { "type": "string", "pattern": "^\\d+\\.\\d+$", "description": "Subcategory ID, X.Y" },
        "n": { "type": "string" },
        "u": {
          "type": "array",
          "items": { "$ref": "#/$defs/useCase" }
        }
      }
    },
    "useCase": {
      "type": "object",
      "required": ["i", "n"],
      "additionalProperties": true,
      "properties": {
        "i": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$", "description": "Use Case ID, X.Y.Z" },
        "n": { "type": "string" }
      }
    }
  }
}
