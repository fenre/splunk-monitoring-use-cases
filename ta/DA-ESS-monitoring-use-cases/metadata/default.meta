# Export correlation searches, governance mappings, and CIM eventtypes
# globally so Enterprise Security can consume them from the ES app context.

[]
access = read : [ * ], write : [ admin, ess_admin ]
export = system

[savedsearches]
export = system

[eventtypes]
export = system

[tags]
export = system

[governance]
export = system

[risk_factor_editor]
export = system

[correlation_searches]
export = system
