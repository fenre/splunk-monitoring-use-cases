# Default export permissions — knowledge objects are readable by everyone in
# the app and inherit the app's role-based access configuration.  No objects
# are exported globally; if you need system-wide visibility, change
# `export = app` to `export = system`.
[]
access = read : [ * ], write : [ admin, power ]
export = app

[macros]
export = system

[eventtypes]
export = system

[tags]
export = system

[savedsearches]
export = none
