# Default export permissions for ITSI content pack objects.  KPI base
# searches, KPI templates, threshold templates and service templates are
# exported globally so ITSI can consume them from any app context.

[]
access = read : [ * ], write : [ admin, itoa_admin ]
export = system

[itsi_kpi_base_search]
export = system

[itsi_kpi_template]
export = system

[itsi_kpi_threshold_template]
export = system

[itsi_service_template]
export = system
