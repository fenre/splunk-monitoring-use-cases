# Generated artefacts — regenerated by build.py / tools/build/build.py
# No manual editing happens here; excluding from Cursor's index
# improves responsiveness. The agent can still read these files
# explicitly via the Read tool when needed.
catalog.json
data.js
provenance.json
scorecard.json
llms-full.txt
llm.txt
llms.txt
sitemap.xml
recently-added.json

# Mirror/regenerated API surface
api/

# Generated crosswalks (large normalised JSONs from external authorities)
data/crosswalks/

# Generated provenance ledger
data/provenance/mapping-ledger.json

# Generated inventory
data/inventory/ucs.json

# v7 build outputs
dist/
dist1/
dist2/
dist-legacy/
dist-content/
.build-tmp/

# Vendored third-party (Swagger UI etc.)
vendor/

# Python virtual environments
.venv/
.venv-feasibility/

# Python build / test caches — already in .gitignore (lines 6 & 39) but
# also hidden from the Cursor agent index so churned bytecode and pytest
# caches don't show up in search results or eat the indexer's budget.
# Closes the second half of F10 from the §P0 health-check plan
# (the secrets/.env block below already closed the first half).
__pycache__/
.pytest_cache/

# Node dependencies
node_modules/

# Local-only stash
other/

# Secrets and local environment overrides
#
# Closes F10 from the §P0 health-check plan (2026-05-12). .gitignore
# (lines 88-90) already prevents these from being committed; this block
# also hides them from the Cursor agent index so a stray Read /
# search request cannot surface credentials. The patterns mirror the
# common dotenv conventions and the project secrets.env.example template.
secrets.env
secrets.env.local
.env
.env.local
.env.*.local
