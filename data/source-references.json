{
  "_meta": {
    "schemaVersion": "1.0",
    "description": "Curated authoritative source library for the Splunk monitoring use case catalog. Maintained by hand; consumed by scripts/generate_doc_references.py. Each entry is a bibliographic record consumable in Wikipedia / academic style (author, year, title, publisher, URL, type). Stable IDs (left-hand keys) MUST NOT be renamed once published; map files reference them by ID.",
    "accessedDate": "2026-05-11",
    "accessedDateNote": "Refresh date stamped on every 'Retrieved <date>' line. Bump when you do a scheduled link-recheck pass; tie this to a release.",
    "schema": {
      "id": "stable kebab-case identifier; permanent",
      "authority": "primary author or issuing organization",
      "year": "publication year (int)",
      "month": "optional, publication month (1-12)",
      "title": "italicised work title, no trailing period",
      "publisher": "publishing organisation if different from authority",
      "type": "one of: regulation | directive | standard | framework | book | paper | documentation | guide | rfc | whitepaper | specification | reference",
      "url": "canonical URL (HTTPS, no tracking params)",
      "edition": "optional; e.g. 'Revision 5', '2nd ed.', 'v4.0'",
      "version": "optional; semantic version string for vendor docs",
      "identifier": "optional; ISBN, DOI, ELI, NIST SP number, RFC number, etc.",
      "accessedYear": "optional override of the auto-stamped retrieval date"
    }
  },

