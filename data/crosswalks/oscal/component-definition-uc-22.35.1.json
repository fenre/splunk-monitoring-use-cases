    "components": [
      {
        "uuid": "5e468af2-e629-5f1e-8532-5f34987c617c",
        "type": "software",
        "title": "Audit-log continuity: detect indexing gap indicating lost evidence",
        "description": "Detects any sourcetype that was previously producing events but has stopped indexing for more than a rolling 60-second window. A regression in event ingestion is the earliest indicator that the audit trail required by almost every modern regulation has been compromised \u2014 whether by accident (agent failure, network partition, licensing quota) or by intent (attacker clearing logs).",
        "purpose": "Without continuous audit logs, compliance claims are unfalsifiable. Auditors across GDPR, HIPAA, PCI DSS, SOC 2, and SOX all treat log-gaps as a finding. This UC lets a customer show the auditor a green dashboard: 'here is every second of the last 30 days, accounted for by source.'",
        "props": [
          {
            "name": "uc-id",
            "value": "UC-22.35.1"
          },
          {
            "name": "control-family",
            "value": "evidence-continuity"
          },
          {
            "name": "owner",
            "value": "CISO"
          },
          {
            "name": "criticality",
            "value": "critical"
          }
        ],
