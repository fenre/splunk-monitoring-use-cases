{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fenre.github.io/splunk-monitoring-use-cases/samples/_schema/sample-manifest.schema.json",
  "title": "UC sample manifest",
  "description": "Schema for samples/UC-<id>/manifest.yaml — consumed by scripts/run_uc_tests.py and scripts/samples_index.py.",
  "type": "object",
  "required": ["uc_id", "sourcetype", "index", "expected", "origin", "last_reviewed"],
  "additionalProperties": false,
  "properties": {
    "uc_id": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "UC identifier, e.g. 1.1.1 — must match an entry in catalog.json."
    },
    "sourcetype": {
      "type": "string",
      "minLength": 1,
      "description": "Splunk sourcetype the positive.log events will be indexed as."
    },
    "index": {
      "type": "string",
      "minLength": 1,
      "description": "Splunk index the events will be written to."
    },
    "source": {
      "type": "string",
      "description": "Optional value for the Splunk 'source' field."
    },
    "host": {
      "type": "string",
      "description": "Optional value for the Splunk 'host' field."
    },
    "timerange": {
      "type": "string",
      "default": "-24h",
      "description": "earliest= value for the SPL run by the test runner."
    },
    "expected": {
      "type": "object",
      "required": ["min_count"],
      "additionalProperties": false,
      "properties": {
        "min_count": {"type": "integer", "minimum": 0},
        "max_count": {"type": "integer", "minimum": 0},
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name": {"type": "string"},
              "values": {"type": "array", "items": {"type": "string"}},
              "min": {"type": "number"},
              "max": {"type": "number"},
              "regex": {"type": "string"}
            }
          }
        }
      }
    },
    "origin": {
      "type": "string",
      "enum": ["hand-authored", "vendor-doc", "synthetic", "contributor"],
      "description": "Provenance of the sample events."
    },
    "origin_ref": {
      "type": "string",
      "format": "uri",
      "description": "Citation URL for the sample origin."
    },
    "last_reviewed": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "description": "ISO date of last maintainer review."
    },
    "reviewer": {
      "type": "string",
      "description": "Identifier of the reviewer (maintainer handle or org)."
    },
    "notes": {
      "type": "string",
      "description": "Free-form notes for future reviewers."
    }
  }
}
