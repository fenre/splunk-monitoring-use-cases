# CODEOWNERS — auto-request review on pull requests.
#
# Syntax reference: https://docs.github.com/en/repositories/managing-your-
# repositorys-settings-and-features/customizing-your-repository/about-code-owners
#
# The LAST matching pattern for a file takes effect, so order matters.
# Keep the default owner at the top; add path-specific rules below it.

# Default owner for everything not otherwise specified.
*                               @fenre

# Build pipeline, CI workflows and release automation.
/build.py                       @fenre
/scripts/                       @fenre
/.github/workflows/             @fenre

# Splunkbase content packs.
/ta/                            @fenre

# Dashboard, data payloads, and static site assets.
/index.html                     @fenre
/data.js                        @fenre
/custom-text.js                 @fenre
/non-technical-view.js          @fenre
/vendor/                        @fenre

# Documentation — lower bar for review, but still code-owner-gated.
/docs/                          @fenre
/README.md                      @fenre
/CHANGELOG.md                   @fenre

# Catalog content (use-cases/*.md).  Heavier review because every change
# ripples into catalog.json and all three Splunkbase packs.
/use-cases/                     @fenre

# Governance documents — require the lead maintainer's sign-off.
/GOVERNANCE.md                  @fenre
/CODE_OF_CONDUCT.md             @fenre
/SECURITY.md                    @fenre
/ROADMAP.md                     @fenre
/CITATION.cff                   @fenre
/CODEOWNERS                     @fenre
/.github/CODEOWNERS             @fenre
