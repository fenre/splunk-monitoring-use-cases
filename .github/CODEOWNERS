# CODEOWNERS — auto-request review on pull requests.
#
# Syntax reference: https://docs.github.com/en/repositories/managing-your-
# repositorys-settings-and-features/customizing-your-repository/about-code-owners
#
# The LAST matching pattern for a file takes effect, so order matters.
# Keep the default owner at the top; add path-specific rules below it.

# Default owner for everything not otherwise specified.
*                               @fenre

# Build pipeline, CI workflows and release automation.
/build.py                       @fenre
/scripts/                       @fenre
/.github/workflows/             @fenre

# Splunkbase content packs.
/ta/                            @fenre

# Dashboard, data payloads, and static site assets.
# (The legacy root-level ``data.js`` was retired in v8.2.0; the
# SSOT-derived ``dist/data.js`` is generated and evicted by the
# build pipeline and never lands as a committed artefact.)
/index.html                     @fenre
/custom-text.js                 @fenre
/non-technical-view.js          @fenre
/vendor/                        @fenre

# Documentation — lower bar for review, but still code-owner-gated.
/docs/                          @fenre
/README.md                      @fenre
/CHANGELOG.md                   @fenre

# Canonical UC content tree (JSON SSOT under content/cat-NN-<slug>/UC-X.Y.Z.json).
# Heavier review because every change ripples into catalog.json,
# the published API, and all three Splunkbase packs.
# Pre-v8.2.0 the legacy ``/use-cases/`` markdown corpus carried the
# same rule; that tree was retired (see docs/migration-status.md).
/content/                       @fenre

# Build pipeline and tooling.
/tools/build/                   @fenre
/tools/audits/                  @fenre

# Schemas — changes here affect validation across the pipeline.
/schemas/                       @fenre

# MCP server — API surface for AI integrations.
/mcp/                           @fenre

# Splunk app packages.
/splunk-apps/                   @fenre

# Governance documents — require the lead maintainer's sign-off.
/GOVERNANCE.md                  @fenre
/CODE_OF_CONDUCT.md             @fenre
/SECURITY.md                    @fenre
/ROADMAP.md                     @fenre
/CITATION.cff                   @fenre
/CODEOWNERS                     @fenre
/.github/CODEOWNERS             @fenre
