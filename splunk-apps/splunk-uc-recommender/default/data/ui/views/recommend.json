{
  "dataSources": {
    "ds_apps": {
      "options": {
        "query": "| inputlookup uc_recommender_inventory | where type=\"app\" | stats dc(name) as v",
        "queryParameters": {
          "earliest": "-1d",
          "latest": "now"
        }
      },
      "type": "ds.search"
    },
    "ds_cim": {
      "options": {
        "query": "| inputlookup uc_recommender_inventory | where type=\"cim_model\" AND extras=\"accelerated\" | stats dc(name) as v",
        "queryParameters": {
          "earliest": "-60m",
          "latest": "now"
        }
      },
      "type": "ds.search"
    },
    "ds_sourcetypes": {
      "options": {
        "query": "| inputlookup uc_recommender_inventory | where type=\"sourcetype\" | stats dc(name) as v",
        "queryParameters": {
          "earliest": "-15m",
          "latest": "now"
        }
      },
      "type": "ds.search"
    }
  },
  "defaults": {
    "dataSources": {
      "global": {
        "options": {
          "refresh": "10m"
        }
      }
    }
  },
  "description": "Match locally-detected data against the upstream use-case catalogue.",
  "inputs": {},
  "layout": {
    "options": {
      "display": "auto-scale",
      "height": 800,
      "width": 1440
    },
    "structure": [
      {
        "item": "kpi_sourcetypes",
        "position": {
          "h": 140,
          "w": 460,
          "x": 10,
          "y": 10
        },
        "type": "block"
      },
      {
        "item": "kpi_cim",
        "position": {
          "h": 140,
          "w": 460,
          "x": 490,
          "y": 10
        },
        "type": "block"
      },
      {
        "item": "kpi_apps",
        "position": {
          "h": 140,
          "w": 460,
          "x": 970,
          "y": 10
        },
        "type": "block"
      },
      {
        "item": "recommender_html",
        "position": {
          "h": 600,
          "w": 1420,
          "x": 10,
          "y": 170
        },
        "type": "block"
      }
    ],
    "type": "absolute"
  },
  "title": "Recommend (Dashboard Studio)",
  "version": "2.0.0",
  "visualizations": {
    "kpi_apps": {
      "dataSources": {
        "primary": "ds_apps"
      },
      "options": {
        "majorColor": "#65a637"
      },
      "title": "Apps detected",
      "type": "splunk.singlevalue"
    },
    "kpi_cim": {
      "dataSources": {
        "primary": "ds_cim"
      },
      "options": {
        "majorColor": "#65a637"
      },
      "title": "CIM models accelerated",
      "type": "splunk.singlevalue"
    },
    "kpi_sourcetypes": {
      "dataSources": {
        "primary": "ds_sourcetypes"
      },
      "options": {
        "majorColor": "#65a637"
      },
      "title": "Sourcetypes detected",
      "type": "splunk.singlevalue"
    },
    "recommender_html": {
      "options": {
        "html": "<div id=\"uc-recommender-studio-root\" data-api-base=\"https://fenre.github.io/splunk-monitoring-use-cases/api/v1\" data-app-name=\"splunk-uc-recommender\" data-mode=\"studio\"><p><em>Loading use-case recommendations…</em></p></div>"
      },
      "type": "viz.html"
    }
  }
}
