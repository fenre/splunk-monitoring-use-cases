{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/fenre/splunk-monitoring-use-cases/schemas/vendor-changelog.schema.json",
  "title": "Vendor product changelog",
  "description": "Hand-curated, machine-readable record of upstream vendor product release changes that affect Splunk field names, log formats, or sourcetypes. One file per vendor under data/vendor-changelog/.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "generated",
    "schema_version",
    "vendor",
    "vendor_display",
    "entries"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Repo-relative path to this schema file (for editor validation)."
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-.+)?$"
    },
    "generated": {
      "type": "string",
      "format": "date",
      "description": "ISO-8601 date (YYYY-MM-DD) when this file was last refreshed."
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "vendor": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$",
      "description": "Vendor slug; must match the filename stem (e.g. cisco.json -> cisco)."
    },
    "vendor_display": {
      "type": "string",
      "minLength": 1
    },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/entry" }
    }
  },
  "$defs": {
    "field_rename": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "product",
        "product_display",
        "release",
        "release_date",
        "change_kind",
        "summary",
        "details",
        "fields_added",
        "fields_removed",
        "fields_renamed",
        "fields_deprecated",
        "spl_impact",
        "affected_uc_categories",
        "source_url",
        "source_kind",
        "severity",
        "added_by",
        "added_date"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z0-9-]+$"
        },
        "product": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$",
          "description": "Equipment model slug under the vendor (e.g. asa, meraki)."
        },
        "product_display": { "type": "string", "minLength": 1 },
        "release": { "type": "string", "minLength": 1 },
        "release_date": { "type": "string", "format": "date" },
        "change_kind": {
          "type": "string",
          "enum": [
            "field-added",
            "field-renamed",
            "field-removed",
            "field-deprecated",
            "format-changed",
            "log-source-renamed",
            "log-source-removed",
            "log-source-added",
            "other"
          ]
        },
        "summary": { "type": "string", "minLength": 10, "maxLength": 400 },
        "details": { "type": "string", "minLength": 20 },
        "fields_added": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "fields_removed": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "fields_renamed": {
          "type": "array",
          "items": { "$ref": "#/$defs/field_rename" }
        },
        "fields_deprecated": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "spl_impact": { "type": "string", "minLength": 10 },
        "affected_uc_categories": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[0-9]+$" },
          "uniqueItems": true,
          "minItems": 1
        },
        "source_url": { "type": "string", "format": "uri" },
        "source_kind": {
          "type": "string",
          "enum": [
            "release-notes",
            "security-advisory",
            "field-guide",
            "api-changelog",
            "maintainer-note"
          ]
        },
        "severity": {
          "type": "string",
          "enum": ["info", "minor", "major", "critical"]
        },
        "added_by": { "type": "string", "minLength": 1 },
        "added_date": { "type": "string", "format": "date" }
      }
    }
  }
}
