{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fenre.github.io/splunk-monitoring-use-cases/schemas/category.schema.json",
  "title": "Splunk Monitoring Use Cases — category index",
  "description": "JSON shape for content/*/ _category.json files (catalog category landing metadata).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "id",
    "name",
    "slug",
    "shortSlug",
    "src",
    "icon",
    "description",
    "quickTip",
    "quickStart",
    "subcategories",
    "useCaseCount"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Reference to this schema file (IDE validation)."
    },
    "id": {
      "type": "integer",
      "minimum": 1,
      "description": "Category number (matches cat-xx in slug)."
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "slug": {
      "type": "string",
      "pattern": "^cat-[0-9]{2}-[a-z0-9-]+$",
      "description": "Directory key under content/, e.g. cat-01-server-compute."
    },
    "shortSlug": {
      "type": "string",
      "pattern": "^cat-[0-9]{2}$"
    },
    "src": {
      "type": "string",
      "description": "Category overview markdown filename in the same folder."
    },
    "icon": {
      "type": "string",
      "minLength": 1,
      "description": "UI icon key (consumer-defined)."
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "quickTip": {
      "type": "string"
    },
    "quickStart": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "title", "criticality", "subcategory"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "criticality": { "type": "string" },
          "subcategory": { "type": "string" }
        }
      }
    },
    "subcategories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "name"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Subcategory id, e.g. 1.1 or 5.13."
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "useCaseCount": {
            "type": "integer",
            "minimum": 0
          },
          "primaryAppTa": { "type": "string" },
          "guide": { "type": "string" },
          "dataSources": { "type": "string" }
        }
      }
    },
    "useCaseCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Total UCs in this category across subcategories."
    }
  }
}
