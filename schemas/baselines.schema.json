{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/fenre/splunk-monitoring-use-cases/schemas/baselines.schema.json",
  "title": "Repo-overhaul baseline capture",
  "description": "Schema for data/baselines/v<VERSION>.json files captured by tools/capture_baselines.py. Used by the repo-overhaul plan §7 to ground every later 'X% smaller' / 'Y× faster' claim in a measured floor.",
  "type": "object",
  "required": ["version", "captured_at", "tracked_file_sizes_bytes", "counts"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[A-Za-z0-9.-]+)?$",
      "description": "Repo VERSION at capture time."
    },
    "captured_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 UTC timestamp."
    },
    "git_head": {
      "type": ["string", "null"],
      "description": "Full SHA of git HEAD at capture time, or null if not in a git checkout."
    },
    "tracked_file_sizes_bytes": {
      "type": "object",
      "description": "Per-file raw + gzipped byte counts. Keys are repo-relative paths.",
      "additionalProperties": {
        "type": "object",
        "required": ["raw", "gzipped"],
        "additionalProperties": false,
        "properties": {
          "raw": { "type": ["integer", "null"], "minimum": 0 },
          "gzipped": { "type": ["integer", "null"], "minimum": 0 }
        }
      }
    },
    "counts": {
      "type": "object",
      "description": "Discrete counts that change per release.",
      "additionalProperties": { "type": ["integer", "null"], "minimum": 0 }
    },
    "tree_sizes_kb": {
      "type": "object",
      "description": "Top-level tree sizes in kilobytes.",
      "additionalProperties": { "type": ["integer", "null"], "minimum": 0 }
    },
    "timing": {
      "type": "object",
      "description": "Wall-clock timings. Lighthouse and MCP-latency numbers are captured manually.",
      "additionalProperties": true
    },
    "notes": { "type": "string" }
  }
}
